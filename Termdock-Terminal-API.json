			]
		},
		{
			"name": "5. Agent Workflow (E2E)",
			"item": [
				{
					"name": "Step 1 - Create Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Session created', function () {",
									"    pm.expect(res.success).to.be.true;",
									"});",
									"if (res.data && res.data.sessionId) {",
									"    pm.collectionVariables.set('e2eSessionId', res.data.sessionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"workspaceId\": \"{{workspaceId}}\",\n    \"logPolicy\": \"persist\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions"]
						}
					},
					"response": []
				},
				{
					"name": "Step 2 - Wait for Ready",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Session is ready', function () {",
									"    pm.expect(res.data.ready).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{e2eSessionId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{e2eSessionId}}", "status"]
						}
					},
					"response": []
				},
				{
					"name": "Step 3 - Send Command",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"data\": \"echo 'Terminal API works!'\",\n    \"appendEnter\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{e2eSessionId}}/input",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{e2eSessionId}}", "input"]
						}
					},
					"response": []
				},
				{
					"name": "Step 4 - Poll Output",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.test('Output contains expected text', function () {",
									"    const text = res.data.text || res.data.lines?.join('\\n') || '';",
									"    pm.expect(text).to.include('Terminal API works!');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{e2eSessionId}}/output?mode=text&lines=10&waitForChange=true&timeoutMs=3000",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{e2eSessionId}}", "output"],
							"query": [
								{"key": "mode", "value": "text"},
								{"key": "lines", "value": "10"},
								{"key": "waitForChange", "value": "true"},
								{"key": "timeoutMs", "value": "3000"}
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 5 - Cleanup",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{e2eSessionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{e2eSessionId}}"]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:3036",
			"type": "string",
			"description": "Development: 3036, Production: 3037"
		},
		{
			"key": "apiToken",
			"value": "",
			"type": "string",
			"description": "Bearer token from Settings > Remote Control > Terminal API"
		},
		{
			"key": "workspaceId",
			"value": "",
			"type": "string",
			"description": "Workspace ID, auto-set by List Workspaces"
		},
		{
			"key": "sessionId",
			"value": "",
			"type": "string",
			"description": "Session ID, auto-set by Create Session"
		},
		{
			"key": "outputCursor",
			"value": "0",
			"type": "string",
			"description": "Cursor for incremental output reads"
		},
		{
			"key": "e2eSessionId",
			"value": "",
			"type": "string",
			"description": "Session ID for E2E workflow test"
		}
	]
}
