{
	"info": {
		"name": "Terminal API - Complete Collection",
		"description": "Termdock Terminal API 完整測試集合，供 AI agent 建立、操控與監聽終端 session",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{apiToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "1. Workspaces",
			"item": [
				{
					"name": "List Workspaces",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"const res = pm.response.json();",
									"pm.test('Has workspaces array', function () {",
									"    pm.expect(res.success).to.be.true;",
									"    pm.expect(res.data).to.have.property('workspaces');",
									"});",
									"if (res.data && res.data.workspaces && res.data.workspaces.length > 0) {",
									"    const ws = res.data.workspaces.find(w => w.type === 'active') || res.data.workspaces[0];",
									"    pm.collectionVariables.set('workspaceId', ws.id);",
									"    console.log('Set workspaceId:', ws.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/workspaces",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "workspaces"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Session Lifecycle",
			"item": [
				{
					"name": "Create Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"const res = pm.response.json();",
									"pm.test('Session created', function () {",
									"    pm.expect(res.success).to.be.true;",
									"    pm.expect(res.data).to.have.property('sessionId');",
									"});",
									"if (res.data && res.data.sessionId) {",
									"    pm.collectionVariables.set('sessionId', res.data.sessionId);",
									"    console.log('Set sessionId:', res.data.sessionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"workspaceId\": \"{{workspaceId}}\",\n    \"logPolicy\": \"persist\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions"]
						}
					},
					"response": []
				},
				{
					"name": "List Sessions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions"]
						}
					},
					"response": []
				},
				{
					"name": "Get Session Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "status"]
						}
					},
					"response": []
				},
				{
					"name": "Destroy Session",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Input & Output",
			"item": [
				{
					"name": "Send Input (JSON)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"data\": \"echo hello world\",\n    \"appendEnter\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/input",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "input"]
						}
					},
					"response": []
				},
				{
					"name": "Send Input (Plain Text)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "text/plain"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "ls -la"
						},
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/input?appendEnter=true",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "input"],
							"query": [
								{
									"key": "appendEnter",
									"value": "true"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Read Output (text mode)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.cursor !== undefined) {",
									"    pm.collectionVariables.set('outputCursor', String(res.data.cursor));",
									"    console.log('Set outputCursor:', res.data.cursor);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/output?mode=text&lines=50",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "output"],
							"query": [
								{
									"key": "mode",
									"value": "text"
								},
								{
									"key": "lines",
									"value": "50"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Read Output (raw mode)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/output?mode=raw&lines=50",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "output"],
							"query": [
								{
									"key": "mode",
									"value": "raw"
								},
								{
									"key": "lines",
									"value": "50"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Read Output (content mode)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/output?mode=content&lines=50&chromeProfile=claude-code",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "output"],
							"query": [
								{
									"key": "mode",
									"value": "content"
								},
								{
									"key": "lines",
									"value": "50"
								},
								{
									"key": "chromeProfile",
									"value": "claude-code"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Read Output (incremental, since cursor)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/output?mode=text&since={{outputCursor}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "output"],
							"query": [
								{
									"key": "mode",
									"value": "text"
								},
								{
									"key": "since",
									"value": "{{outputCursor}}"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Read Output (long-poll, wait for change)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/output?mode=text&since={{outputCursor}}&waitForChange=true&timeoutMs=5000",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "output"],
							"query": [
								{
									"key": "mode",
									"value": "text"
								},
								{
									"key": "since",
									"value": "{{outputCursor}}"
								},
								{
									"key": "waitForChange",
									"value": "true"
								},
								{
									"key": "timeoutMs",
									"value": "5000"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Session Log",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/terminal/sessions/{{sessionId}}/log",
							"host": ["{{baseUrl}}"],
							"path": ["api", "terminal", "sessions", "{{sessionId}}", "log"]
						}
					},
					"response": []
				}
			]
		},
		{
